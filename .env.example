POSTGRES_DB=cozytts
POSTGRES_USER=cozytts
POSTGRES_PASSWORD=cozytts

API_PORT=8080
FRONTEND_PORT=3000

PIPER_BIN_PATH=/opt/piper/bin/piper
PIPER_MODELS_PATH=/models
FFMPEG_BIN_PATH=/usr/bin/ffmpeg
AUDIO_OUTPUT_PATH=/data/audio
TTS_TEMP_PATH=/tmp/cozytts
TTS_MAX_CHUNK_CHARACTERS=1800
APPLY_MIGRATIONS=true

QWEN_TTS_ENDPOINT=http://qwen-tts:8090
QWEN_TTS_PORT=8090
QWEN_TTS_TIMEOUT_MINUTES=30
QWEN_MAX_CHUNK_CHARACTERS=1200
QWEN_OUTPUT_SAMPLE_RATE=24000
QWEN_DEFAULT_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
QWEN_DEVICE_MAP=auto
QWEN_TORCH_DTYPE=
QWEN_ATTN_IMPLEMENTATION=
